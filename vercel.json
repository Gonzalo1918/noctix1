{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "outputDirectory": "dist/app",
  "rewrites": [
    {
      "source": "/((?!assets/|.*\\.(?:js|css|png|jpg|jpeg|gif|ico|svg|webp|woff|woff2|ttf|eot|json|map)).*)",
      "destination": "/index.html"
    }
  ]
}
